"""
Module: service_enumerator.py
==============================
Identifies service versions and OS fingerprints on open ports.

Probes:
  - HTTP/HTTPS  → Server header, X-Powered-By, framework hints
  - SSH         → Protocol version, software string
  - FTP         → Software banner
  - SMTP        → EHLO response, software string
  - MySQL       → Handshake packet → version string
  - Redis       → INFO command → server version
  - SMB         → OS/Version (via NetBIOS name service)
  - Generic     → Raw banner probe

Usage:
    python toolkit.py enumerate --target 192.168.1.1 --confirm
    python toolkit.py enumerate --target 192.168.1.1 --ports 22,80,443 --confirm
"""

import socket
import ssl
import re
import struct
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor, as_completed

# Ports to probe when none are specified
DEFAULT_PORTS = [
    21, 22, 23, 25, 53, 80, 110, 111, 135, 139, 143, 389,
    443, 445, 993, 995, 1433, 1521, 3306, 3389, 5432, 5900,
    6379, 8080, 8443, 27017,
]

SERVICE_MAP = {
    21: "ftp", 22: "ssh", 23: "telnet", 25: "smtp",
    80: "http", 110: "pop3", 143: "imap", 389: "ldap",
    443: "https", 445: "smb", 993: "imaps", 995: "pop3s",
    1433: "mssql", 1521: "oracle", 3306: "mysql",
    3389: "rdp", 5432: "postgresql", 5900: "vnc",
    6379: "redis", 8080: "http", 8443: "https", 27017: "mongodb",
}


# ─── Protocol-specific probes ────────────────────────────────────────────────

def probe_http(ip: str, port: int, timeout: float, use_ssl: bool = False) -> dict:
    """HTTP HEAD request → extract Server, X-Powered-By, etc."""
    info = {"protocol": "https" if use_ssl else "http"}
    try:
        ctx = ssl.create_default_context() if use_ssl else None
        if use_ssl:
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
        with socket.create_connection((ip, port), timeout=timeout) as raw:
            s = ctx.wrap_socket(raw, server_hostname=ip) if use_ssl else raw
            s.sendall(
                f"HEAD / HTTP/1.1\r\nHost: {ip}\r\nConnection: close\r\n\r\n"
                .encode()
            )
            resp = s.recv(4096).decode("utf-8", errors="replace")

        headers = {}
        for line in resp.splitlines()[1:]:
            if ": " in line:
                k, v = line.split(": ", 1)
                headers[k.lower()] = v.strip()

        # Parse status line
        status_match = re.match(r"HTTP/[\d.]+ (\d+)", resp)
        info["status"] = status_match.group(1) if status_match else "?"

        for key in ("server", "x-powered-by", "x-aspnet-version",
                    "x-generator", "x-drupal-cache", "via"):
            if key in headers:
                info[key] = headers[key]

        # Security header analysis
        security = {}
        for sec in ("strict-transport-security", "content-security-policy",
                    "x-frame-options", "x-xss-protection",
                    "x-content-type-options", "referrer-policy"):
            security[sec] = "present" if sec in headers else "MISSING"
        info["security_headers"] = security

    except Exception as e:
        info["error"] = str(e)
    return info


def probe_ssh(ip: str, port: int, timeout: float) -> dict:
    """Read SSH protocol banner."""
    info = {"protocol": "ssh"}
    try:
        with socket.create_connection((ip, port), timeout=timeout) as s:
            banner = s.recv(256).decode("utf-8", errors="replace").strip()
            info["banner"] = banner
            # e.g. SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.4
            m = re.match(r"SSH-(\S+)-(\S+)", banner)
            if m:
                info["ssh_version"] = m.group(1)
                info["software"] = m.group(2)
    except Exception as e:
        info["error"] = str(e)
    return info


def probe_ftp(ip: str, port: int, timeout: float) -> dict:
    """Read FTP banner and check for anonymous login."""
    info = {"protocol": "ftp"}
    try:
        with socket.create_connection((ip, port), timeout=timeout) as s:
            banner = s.recv(512).decode("utf-8", errors="replace").strip()
            info["banner"] = banner.splitlines()[0]
            # Check anonymous login
            s.sendall(b"USER anonymous\r\n")
            r1 = s.recv(128).decode("utf-8", errors="replace")
            if r1.startswith("331"):
                s.sendall(b"PASS anonymous@example.com\r\n")
                r2 = s.recv(128).decode("utf-8", errors="replace")
                info["anonymous_login"] = r2.startswith("230")
            else:
                info["anonymous_login"] = False
    except Exception as e:
        info["error"] = str(e)
    return info


def probe_smtp(ip: str, port: int, timeout: float) -> dict:
    """Read SMTP banner and EHLO response."""
    info = {"protocol": "smtp"}
    try:
        with socket.create_connection((ip, port), timeout=timeout) as s:
            banner = s.recv(512).decode("utf-8", errors="replace").strip()
            info["banner"] = banner.splitlines()[0]
            s.sendall(b"EHLO pentest.local\r\n")
            ehlo = s.recv(1024).decode("utf-8", errors="replace")
            extensions = [
                line[4:] for line in ehlo.splitlines()
                if line and line[0].isdigit()
            ]
            info["extensions"] = extensions
    except Exception as e:
        info["error"] = str(e)
    return info


def probe_mysql(ip: str, port: int, timeout: float) -> dict:
    """Parse MySQL initial handshake packet to extract version."""
    info = {"protocol": "mysql"}
    try:
        with socket.create_connection((ip, port), timeout=timeout) as s:
            data = s.recv(1024)
            if len(data) > 5 and data[4] == 0x0a:
                # Null-terminated version string starts at offset 5
                end = data.index(b"\x00", 5)
                info["version"] = data[5:end].decode("utf-8", errors="replace")
    except Exception as e:
        info["error"] = str(e)
    return info


def probe_redis(ip: str, port: int, timeout: float) -> dict:
    """Send Redis INFO server command and parse version."""
    info = {"protocol": "redis"}
    try:
        with socket.create_connection((ip, port), timeout=timeout) as s:
            s.sendall(b"INFO server\r\n")
            resp = s.recv(4096).decode("utf-8", errors="replace")
            for line in resp.splitlines():
                if line.startswith("redis_version:"):
                    info["version"] = line.split(":")[1].strip()
                elif line.startswith("os:"):
                    info["os"] = line.split(":", 1)[1].strip()
                elif line.startswith("tcp_port:"):
                    info["port"] = line.split(":")[1].strip()
            # Check if auth is required
            if "NOAUTH" in resp or "Authentication required" in resp:
                info["auth_required"] = True
            else:
                info["auth_required"] = False
    except Exception as e:
        info["error"] = str(e)
    return info


def probe_generic(ip: str, port: int, timeout: float) -> dict:
    """Generic banner grab."""
    info = {"protocol": "unknown"}
    try:
        with socket.create_connection((ip, port), timeout=timeout) as s:
            s.settimeout(timeout)
            try:
                banner = s.recv(1024).decode("utf-8", errors="replace").strip()
                info["banner"] = banner[:200]
            except socket.timeout:
                # Try sending a newline
                s.sendall(b"\r\n")
                try:
                    banner = s.recv(1024).decode("utf-8", errors="replace").strip()
                    info["banner"] = banner[:200]
                except Exception:
                    pass
    except Exception as e:
        info["error"] = str(e)
    return info


PROBE_DISPATCH = {
    "ftp":        probe_ftp,
    "ssh":        probe_ssh,
    "smtp":       probe_smtp,
    "http":       lambda ip, p, t: probe_http(ip, p, t, use_ssl=False),
    "https":      lambda ip, p, t: probe_http(ip, p, t, use_ssl=True),
    "mysql":      probe_mysql,
    "redis":      probe_redis,
}


def probe_port(ip: str, port: int, timeout: float) -> dict | None:
    """Detect if port is open, then run the appropriate probe."""
    try:
        socket.create_connection((ip, port), timeout=timeout).close()
    except Exception:
        return None  # Port closed / filtered

    service_key = SERVICE_MAP.get(port, "generic")
    probe_fn = PROBE_DISPATCH.get(service_key, probe_generic)
    result = probe_fn(ip, port, timeout)
    result["port"] = port
    result["state"] = "open"
    return result


def run(args) -> dict:
    target = args.target
    timeout = getattr(args, "timeout", 3.0)

    try:
        ip = socket.gethostbyname(target)
    except socket.gaierror:
        print(f"❌ Cannot resolve host: {target}")
        return {}

    port_str = getattr(args, "ports", None)
    if port_str:
        from modules.port_scanner import parse_ports
        ports = parse_ports(port_str)
    else:
        ports = DEFAULT_PORTS

    print(f"\n🔬 Service Enumeration: {target} ({ip})")
    print(f"   Probing {len(ports)} port(s)  |  timeout={timeout}s\n")

    findings = []
    with ThreadPoolExecutor(max_workers=30) as executor:
        future_map = {executor.submit(probe_port, ip, p, timeout): p for p in ports}
        for future in as_completed(future_map):
            result = future.result()
            if result:
                findings.append(result)
                port = result["port"]
                protocol = result.get("protocol", "?")
                version = (result.get("version") or result.get("software") or
                           result.get("banner", "")[:60])
                print(f"  [{port}] {protocol:<8}  {version}")

    findings.sort(key=lambda x: x["port"])

    print(f"\n  Found {len(findings)} open service(s).")
    return {
        "module": "enumerate",
        "target": target,
        "ip": ip,
        "scan_time": datetime.now().isoformat(),
        "services": findings,
    }
