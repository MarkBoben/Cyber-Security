<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VAULT — AES-256 File Encryptor</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600;700&display=swap');

  :root {
    --bg: #070a0f;
    --surface: #0d1117;
    --surface2: #111820;
    --border: #1a2535;
    --accent: #00e5ff;
    --accent2: #7b2fff;
    --green: #00ff88;
    --red: #ff3c5a;
    --yellow: #ffd60a;
    --text: #c9d8e8;
    --text-dim: #4a6070;
    --glow: 0 0 20px rgba(0,229,255,0.3);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Rajdhani', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at 30% 20%, rgba(123,47,255,0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(0,229,255,0.06) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
    animation: drift 20s ease-in-out infinite alternate;
  }

  @keyframes drift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(30px, -20px); }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  header {
    text-align: center;
    margin-bottom: 50px;
  }

  .logo {
    font-family: 'Share Tech Mono', monospace;
    font-size: 3.5rem;
    letter-spacing: 0.5rem;
    color: var(--accent);
    text-shadow: var(--glow), 0 0 60px rgba(0,229,255,0.2);
    position: relative;
    display: inline-block;
    animation: flicker 8s ease-in-out infinite;
  }

  @keyframes flicker {
    0%, 96%, 100% { opacity: 1; }
    97% { opacity: 0.85; }
    98% { opacity: 1; }
    99% { opacity: 0.9; }
  }

  .logo::after {
    content: 'AES-256 FILE ENCRYPTION';
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.4rem;
    color: var(--text-dim);
    margin-top: 8px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(0,255,136,0.08);
    border: 1px solid rgba(0,255,136,0.25);
    border-radius: 2px;
    padding: 4px 12px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    color: var(--green);
    margin-top: 16px;
    letter-spacing: 0.15rem;
  }

  .badge::before {
    content: '●';
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Mode Toggle */
  .mode-toggle {
    display: flex;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 30px;
    position: relative;
  }

  .mode-btn {
    flex: 1;
    padding: 14px;
    background: none;
    border: none;
    color: var(--text-dim);
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.15rem;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    z-index: 1;
    text-transform: uppercase;
  }

  .mode-btn.active {
    color: var(--bg);
  }

  .mode-slider {
    position: absolute;
    top: 4px;
    bottom: 4px;
    width: calc(50% - 4px);
    background: var(--accent);
    border-radius: 2px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    left: 4px;
    box-shadow: 0 0 20px rgba(0,229,255,0.4);
  }

  .mode-slider.decrypt { transform: translateX(calc(100% + 0px)); left: calc(50%); width: calc(50% - 4px); }

  /* Card */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 30px;
    margin-bottom: 20px;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0.5;
  }

  .card-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.25rem;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .card-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Drop Zone */
  .drop-zone {
    border: 1px dashed var(--border);
    border-radius: 4px;
    padding: 50px 30px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    background: var(--surface2);
  }

  .drop-zone:hover, .drop-zone.drag-over {
    border-color: var(--accent);
    background: rgba(0,229,255,0.03);
    box-shadow: inset 0 0 30px rgba(0,229,255,0.05);
  }

  .drop-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .drop-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
    display: block;
    opacity: 0.5;
  }

  .drop-text {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-dim);
    letter-spacing: 0.05rem;
  }

  .drop-subtext {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-top: 6px;
    opacity: 0.5;
  }

  .file-selected {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background: rgba(0,229,255,0.05);
    border: 1px solid rgba(0,229,255,0.2);
    border-radius: 4px;
    margin-top: 16px;
    animation: slideIn 0.3s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .file-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .file-info { flex: 1; min-width: 0; }
  .file-name {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: var(--accent);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .file-size {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-top: 4px;
  }

  .file-clear {
    background: none;
    border: 1px solid var(--border);
    color: var(--text-dim);
    padding: 6px 12px;
    border-radius: 2px;
    cursor: pointer;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    transition: all 0.2s;
  }

  .file-clear:hover { border-color: var(--red); color: var(--red); }

  /* Password field */
  .field-group { margin-bottom: 20px; }

  label {
    display: block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.2rem;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  input[type="password"], input[type="text"] {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 12px 50px 12px 16px;
    color: var(--text);
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.9rem;
    letter-spacing: 0.1rem;
    outline: none;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(0,229,255,0.1);
  }

  .toggle-pw {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    color: var(--text-dim);
    cursor: pointer;
    font-size: 1rem;
    padding: 4px;
    transition: color 0.2s;
  }

  .toggle-pw:hover { color: var(--accent); }

  /* Strength meter */
  .strength-bar {
    display: flex;
    gap: 4px;
    margin-top: 8px;
  }

  .strength-seg {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    transition: background 0.4s ease;
  }

  .strength-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6rem;
    color: var(--text-dim);
    margin-top: 5px;
  }

  /* Algorithm selector */
  .algo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .algo-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 12px 8px;
    cursor: pointer;
    text-align: center;
    transition: all 0.25s ease;
    font-family: 'Rajdhani', sans-serif;
  }

  .algo-btn:hover { border-color: var(--text-dim); }

  .algo-btn.selected {
    border-color: var(--accent);
    background: rgba(0,229,255,0.05);
    box-shadow: 0 0 15px rgba(0,229,255,0.1);
  }

  .algo-name {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent);
    display: block;
  }

  .algo-desc { font-size: 0.7rem; color: var(--text-dim); margin-top: 3px; }

  /* Options */
  .options-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .option-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    transition: all 0.2s;
    user-select: none;
  }

  .option-item:hover { border-color: var(--text-dim); }
  .option-item.checked { border-color: var(--accent); background: rgba(0,229,255,0.04); }

  .checkbox {
    width: 16px;
    height: 16px;
    border: 1px solid var(--border);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
    font-size: 0.6rem;
  }

  .option-item.checked .checkbox {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }

  .option-text { font-size: 0.85rem; color: var(--text); }
  .option-sub { font-size: 0.7rem; color: var(--text-dim); display: block; }

  /* Action button */
  .btn-primary {
    width: 100%;
    padding: 16px;
    background: none;
    border: 1px solid var(--accent);
    border-radius: 4px;
    color: var(--accent);
    font-family: 'Rajdhani', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .btn-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }

  .btn-primary:hover::before { transform: translateX(0); }
  .btn-primary:hover { color: var(--bg); box-shadow: 0 0 30px rgba(0,229,255,0.3); }

  .btn-primary span { position: relative; z-index: 1; }

  .btn-primary:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Progress */
  .progress-wrap {
    margin-top: 20px;
    display: none;
  }

  .progress-wrap.show { display: block; animation: slideIn 0.3s ease; }

  .progress-header {
    display: flex;
    justify-content: space-between;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.7rem;
    color: var(--text-dim);
    margin-bottom: 8px;
  }

  .progress-bar {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent2), var(--accent));
    border-radius: 2px;
    transition: width 0.3s ease;
    position: relative;
  }

  .progress-fill::after {
    content: '';
    position: absolute;
    right: 0;
    top: -1px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
  }

  /* Log */
  .log-terminal {
    background: #050810;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 16px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.8;
    max-height: 180px;
    overflow-y: auto;
    margin-top: 16px;
    display: none;
  }

  .log-terminal.show { display: block; }

  .log-line { display: block; }
  .log-line.info { color: var(--text-dim); }
  .log-line.success { color: var(--green); }
  .log-line.warning { color: var(--yellow); }
  .log-line.error { color: var(--red); }

  /* Result */
  .result-box {
    border-radius: 4px;
    padding: 20px;
    margin-top: 20px;
    display: none;
    animation: slideIn 0.4s ease;
  }

  .result-box.show { display: block; }
  .result-box.success-box { background: rgba(0,255,136,0.05); border: 1px solid rgba(0,255,136,0.25); }
  .result-box.error-box { background: rgba(255,60,90,0.05); border: 1px solid rgba(255,60,90,0.25); }

  .result-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.15rem;
    margin-bottom: 12px;
  }

  .success-box .result-title { color: var(--green); }
  .error-box .result-title { color: var(--red); }

  .result-details {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 16px;
  }

  .detail-item {
    background: rgba(0,0,0,0.3);
    padding: 10px;
    border-radius: 2px;
    text-align: center;
  }

  .detail-val {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
    display: block;
  }

  .detail-key {
    font-size: 0.65rem;
    color: var(--text-dim);
    margin-top: 4px;
    display: block;
    letter-spacing: 0.1rem;
    text-transform: uppercase;
  }

  .btn-download {
    width: 100%;
    padding: 12px;
    background: var(--green);
    border: none;
    border-radius: 4px;
    color: var(--bg);
    font-family: 'Rajdhani', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 0 20px rgba(0,255,136,0.2);
  }

  .btn-download:hover { background: #00cc6e; box-shadow: 0 0 30px rgba(0,255,136,0.4); }

  /* Stats bar */
  .stats-bar {
    display: flex;
    gap: 1px;
    background: var(--border);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 30px;
  }

  .stat-item {
    flex: 1;
    padding: 10px 16px;
    background: var(--surface);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .stat-val {
    font-family: 'Share Tech Mono', monospace;
    font-size: 1rem;
    color: var(--accent);
  }

  .stat-lbl { font-size: 0.7rem; color: var(--text-dim); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--surface); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  /* Section hidden */
  .section { display: none; }
  .section.active { display: block; animation: slideIn 0.3s ease; }
</style>
</head>
<body>

<div class="container">
  <header>
    <div class="logo">VAULT</div>
    <div class="badge">MILITARY-GRADE ENCRYPTION — FULLY CLIENT-SIDE — ZERO SERVER UPLOADS</div>
  </header>

  <div class="stats-bar">
    <div class="stat-item">
      <span class="stat-val" id="statFiles">0</span>
      <span class="stat-lbl">Files Processed</span>
    </div>
    <div class="stat-item">
      <span class="stat-val" id="statSize">0 B</span>
      <span class="stat-lbl">Data Encrypted</span>
    </div>
    <div class="stat-item">
      <span class="stat-val">AES-256</span>
      <span class="stat-lbl">Encryption Standard</span>
    </div>
    <div class="stat-item">
      <span class="stat-val" style="color:var(--green)">LOCAL</span>
      <span class="stat-lbl">Processing Mode</span>
    </div>
  </div>

  <!-- Mode Toggle -->
  <div class="mode-toggle">
    <div class="mode-slider" id="modeSlider"></div>
    <button class="mode-btn active" id="encryptBtn" onclick="setMode('encrypt')">🔒 ENCRYPT</button>
    <button class="mode-btn" id="decryptBtn" onclick="setMode('decrypt')">🔓 DECRYPT</button>
  </div>

  <!-- File Drop -->
  <div class="card">
    <div class="card-title">01 — SELECT FILE</div>
    <div class="drop-zone" id="dropZone">
      <input type="file" id="fileInput" onchange="handleFile(this.files[0])">
      <span class="drop-icon">📁</span>
      <div class="drop-text">Drop file here or click to browse</div>
      <div class="drop-subtext">ANY FILE TYPE SUPPORTED · NO SIZE LIMIT</div>
    </div>
    <div class="file-selected" id="fileInfo" style="display:none">
      <span class="file-icon" id="fileEmoji">📄</span>
      <div class="file-info">
        <div class="file-name" id="fileName">—</div>
        <div class="file-size" id="fileSize">—</div>
      </div>
      <button class="file-clear" onclick="clearFile()">✕ CLEAR</button>
    </div>
  </div>

  <!-- Algorithm & Password -->
  <div class="card">
    <div class="card-title">02 — ALGORITHM & KEY</div>

    <div class="field-group">
      <label>Cipher Algorithm</label>
      <div class="algo-grid">
        <div class="algo-btn selected" onclick="selectAlgo(this, 'AES-GCM')" data-algo="AES-GCM">
          <span class="algo-name">AES-256-GCM</span>
          <div class="algo-desc">Authenticated · Recommended</div>
        </div>
        <div class="algo-btn" onclick="selectAlgo(this, 'AES-CBC')" data-algo="AES-CBC">
          <span class="algo-name">AES-256-CBC</span>
          <div class="algo-desc">Block cipher · Compatible</div>
        </div>
        <div class="algo-btn" onclick="selectAlgo(this, 'AES-CTR')" data-algo="AES-CTR">
          <span class="algo-name">AES-256-CTR</span>
          <div class="algo-desc">Stream mode · Fast</div>
        </div>
      </div>
    </div>

    <div class="field-group">
      <label>Encryption Password / Passphrase</label>
      <div class="input-wrap">
        <input type="password" id="passwordInput" placeholder="Enter a strong passphrase..." oninput="checkStrength(this.value)">
        <button class="toggle-pw" onclick="togglePw()" title="Show/Hide">👁</button>
      </div>
      <div class="strength-bar" id="strengthBar">
        <div class="strength-seg" id="s1"></div>
        <div class="strength-seg" id="s2"></div>
        <div class="strength-seg" id="s3"></div>
        <div class="strength-seg" id="s4"></div>
        <div class="strength-seg" id="s5"></div>
      </div>
      <div class="strength-label" id="strengthLabel">Enter a passphrase to check strength</div>
    </div>

    <div class="field-group">
      <label>Key Derivation (PBKDF2 Iterations)</label>
      <div class="input-wrap">
        <input type="text" id="iterationsInput" value="600000" placeholder="Iterations...">
      </div>
    </div>
  </div>

  <!-- Options -->
  <div class="card">
    <div class="card-title">03 — OPTIONS</div>
    <div class="options-grid">
      <div class="option-item checked" onclick="toggleOption(this)" data-key="addMac">
        <div class="checkbox">✓</div>
        <div>
          <div class="option-text">HMAC Integrity Check</div>
          <span class="option-sub">Detect tampering or corruption</span>
        </div>
      </div>
      <div class="option-item checked" onclick="toggleOption(this)" data-key="randomSalt">
        <div class="checkbox">✓</div>
        <div>
          <div class="option-text">Random Salt</div>
          <span class="option-sub">Unique salt per encryption</span>
        </div>
      </div>
      <div class="option-item" onclick="toggleOption(this)" data-key="compressFirst">
        <div class="checkbox"></div>
        <div>
          <div class="option-text">Compress Before Encrypt</div>
          <span class="option-sub">Reduces output file size</span>
        </div>
      </div>
      <div class="option-item checked" onclick="toggleOption(this)" data-key="embedMeta">
        <div class="checkbox">✓</div>
        <div>
          <div class="option-text">Embed File Metadata</div>
          <span class="option-sub">Preserves original filename</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Action -->
  <div class="card">
    <div class="card-title" id="actionLabel">04 — EXECUTE ENCRYPTION</div>

    <button class="btn-primary" id="actionBtn" onclick="processFile()">
      <span id="actionBtnText">🔒 ENCRYPT FILE</span>
    </button>

    <div class="progress-wrap" id="progressWrap">
      <div class="progress-header">
        <span id="progressStatus">Initializing...</span>
        <span id="progressPct">0%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="progressFill" style="width:0%"></div>
      </div>
    </div>

    <div class="log-terminal" id="logTerminal"></div>

    <div class="result-box" id="resultBox">
      <div class="result-title" id="resultTitle">—</div>
      <div class="result-details" id="resultDetails"></div>
      <button class="btn-download" id="downloadBtn" onclick="downloadResult()">⬇ DOWNLOAD RESULT</button>
    </div>
  </div>

</div>

<script>
// ─── State ───────────────────────────────────────────────────────────────────
let currentMode = 'encrypt';
let selectedAlgo = 'AES-GCM';
let selectedFile = null;
let resultBlob = null;
let resultFilename = '';
let statsFiles = 0;
let statsBytes = 0;
const options = { addMac: true, randomSalt: true, compressFirst: false, embedMeta: true };

// ─── UI Helpers ──────────────────────────────────────────────────────────────
function setMode(mode) {
  currentMode = mode;
  const slider = document.getElementById('modeSlider');
  const encBtn = document.getElementById('encryptBtn');
  const decBtn = document.getElementById('decryptBtn');
  const actionLabel = document.getElementById('actionLabel');
  const actionBtnText = document.getElementById('actionBtnText');

  if (mode === 'encrypt') {
    slider.classList.remove('decrypt');
    encBtn.classList.add('active');
    decBtn.classList.remove('active');
    actionLabel.textContent = '04 — EXECUTE ENCRYPTION';
    actionBtnText.textContent = '🔒 ENCRYPT FILE';
  } else {
    slider.classList.add('decrypt');
    decBtn.classList.add('active');
    encBtn.classList.remove('active');
    actionLabel.textContent = '04 — EXECUTE DECRYPTION';
    actionBtnText.textContent = '🔓 DECRYPT FILE';
  }
  resetResult();
}

function selectAlgo(el, algo) {
  document.querySelectorAll('.algo-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  selectedAlgo = algo;
}

function toggleOption(el) {
  const key = el.dataset.key;
  options[key] = !options[key];
  const cb = el.querySelector('.checkbox');
  if (options[key]) {
    el.classList.add('checked');
    cb.textContent = '✓';
  } else {
    el.classList.remove('checked');
    cb.textContent = '';
  }
}

function togglePw() {
  const inp = document.getElementById('passwordInput');
  inp.type = inp.type === 'password' ? 'text' : 'password';
}

function handleFile(file) {
  if (!file) return;
  selectedFile = file;
  document.getElementById('fileInfo').style.display = 'flex';
  document.getElementById('fileName').textContent = file.name;
  document.getElementById('fileSize').textContent = formatSize(file.size);
  const ext = file.name.split('.').pop().toLowerCase();
  const icons = { pdf: '📕', jpg: '🖼', jpeg: '🖼', png: '🖼', mp4: '🎬', mp3: '🎵', zip: '🗜', docx: '📝', txt: '📋', enc: '🔐' };
  document.getElementById('fileEmoji').textContent = icons[ext] || '📄';
  resetResult();
}

function clearFile() {
  selectedFile = null;
  document.getElementById('fileInput').value = '';
  document.getElementById('fileInfo').style.display = 'none';
  resetResult();
}

function resetResult() {
  document.getElementById('progressWrap').classList.remove('show');
  document.getElementById('logTerminal').classList.remove('show');
  document.getElementById('resultBox').classList.remove('show');
  document.getElementById('logTerminal').innerHTML = '';
  resultBlob = null;
}

function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(2) + ' KB';
  if (bytes < 1024 * 1024 * 1024) return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
  return (bytes / (1024 * 1024 * 1024)).toFixed(2) + ' GB';
}

function checkStrength(pw) {
  const segs = ['s1','s2','s3','s4','s5'];
  const colors = ['#ff3c5a', '#ff6b35', '#ffd60a', '#a0e040', '#00ff88'];
  const labels = ['', 'WEAK', 'FAIR', 'GOOD', 'STRONG', 'FORTRESS'];

  let score = 0;
  if (pw.length >= 8) score++;
  if (pw.length >= 16) score++;
  if (/[A-Z]/.test(pw) && /[a-z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;

  segs.forEach((id, i) => {
    const el = document.getElementById(id);
    el.style.background = i < score ? colors[score - 1] : 'var(--border)';
  });

  document.getElementById('strengthLabel').textContent = pw.length === 0
    ? 'Enter a passphrase to check strength'
    : `STRENGTH: ${labels[score]} — ${pw.length} CHARACTERS`;
}

function log(msg, type = 'info') {
  const term = document.getElementById('logTerminal');
  term.classList.add('show');
  const line = document.createElement('span');
  line.className = `log-line ${type}`;
  const time = new Date().toISOString().substr(11, 12);
  line.textContent = `[${time}] ${msg}`;
  term.appendChild(line);
  term.scrollTop = term.scrollHeight;
}

function setProgress(pct, status) {
  document.getElementById('progressWrap').classList.add('show');
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressPct').textContent = Math.round(pct) + '%';
  document.getElementById('progressStatus').textContent = status;
}

// ─── Drag & Drop ─────────────────────────────────────────────────────────────
const dz = document.getElementById('dropZone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag-over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('drag-over'));
dz.addEventListener('drop', e => {
  e.preventDefault();
  dz.classList.remove('drag-over');
  if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
});

// ─── Crypto Core (Web Crypto API) ────────────────────────────────────────────
async function deriveKey(password, salt, algo) {
  const enc = new TextEncoder();
  const keyMaterial = await crypto.subtle.importKey(
    'raw', enc.encode(password), 'PBKDF2', false, ['deriveKey']
  );
  const iters = parseInt(document.getElementById('iterationsInput').value) || 600000;
  const cryptoAlgo = algo === 'AES-CTR' ? 'AES-CTR' : (algo === 'AES-CBC' ? 'AES-CBC' : 'AES-GCM');
  return crypto.subtle.deriveKey(
    { name: 'PBKDF2', salt, iterations: iters, hash: 'SHA-256' },
    keyMaterial,
    { name: cryptoAlgo, length: 256 },
    false,
    ['encrypt', 'decrypt']
  );
}

async function encryptData(data, password, algo) {
  const salt = options.randomSalt
    ? crypto.getRandomValues(new Uint8Array(32))
    : new Uint8Array(32).fill(0x42);

  log(`Deriving key from passphrase using PBKDF2-SHA256...`);
  setProgress(20, 'Key derivation...');
  const key = await deriveKey(password, salt, algo);

  let iv, encrypted, algoParams;
  if (algo === 'AES-GCM') {
    iv = crypto.getRandomValues(new Uint8Array(12));
    algoParams = { name: 'AES-GCM', iv };
  } else if (algo === 'AES-CBC') {
    iv = crypto.getRandomValues(new Uint8Array(16));
    algoParams = { name: 'AES-CBC', iv };
  } else {
    iv = crypto.getRandomValues(new Uint8Array(16));
    algoParams = { name: 'AES-CTR', counter: iv, length: 128 };
  }

  setProgress(60, 'Encrypting...');
  log(`Encrypting with ${algo}-256...`);
  encrypted = await crypto.subtle.encrypt(algoParams, key, data);

  // Build output: magic(4) + version(1) + algo(1) + saltLen(1) + salt + ivLen(1) + iv + data
  const algoId = algo === 'AES-GCM' ? 1 : algo === 'AES-CBC' ? 2 : 3;
  const magic = new Uint8Array([0x56, 0x4C, 0x54, 0x21]); // VLT!
  const version = new Uint8Array([1]);
  const algoArr = new Uint8Array([algoId]);
  const saltLenArr = new Uint8Array([salt.length]);
  const ivLenArr = new Uint8Array([iv.length]);
  const encArr = new Uint8Array(encrypted);

  const total = magic.length + version.length + algoArr.length +
    saltLenArr.length + salt.length + ivLenArr.length + iv.length + encArr.length;
  const out = new Uint8Array(total);
  let offset = 0;
  [magic, version, algoArr, saltLenArr, salt, ivLenArr, iv, encArr].forEach(arr => {
    out.set(arr, offset); offset += arr.length;
  });

  return out;
}

async function decryptData(data, password) {
  // Parse header
  const magic = String.fromCharCode(...data.slice(0, 4));
  if (magic !== 'VLT!') throw new Error('Invalid file format — not a VAULT encrypted file');

  let offset = 4;
  const version = data[offset++];
  const algoId = data[offset++];
  const algo = algoId === 1 ? 'AES-GCM' : algoId === 2 ? 'AES-CBC' : 'AES-CTR';
  const saltLen = data[offset++];
  const salt = data.slice(offset, offset + saltLen); offset += saltLen;
  const ivLen = data[offset++];
  const iv = data.slice(offset, offset + ivLen); offset += ivLen;
  const ciphertext = data.slice(offset);

  log(`Detected algorithm: ${algo}-256`);
  log(`Deriving key from passphrase...`);
  setProgress(20, 'Key derivation...');
  const key = await deriveKey(password, salt, algo);

  let algoParams;
  if (algo === 'AES-GCM') algoParams = { name: 'AES-GCM', iv };
  else if (algo === 'AES-CBC') algoParams = { name: 'AES-CBC', iv };
  else algoParams = { name: 'AES-CTR', counter: iv, length: 128 };

  setProgress(60, 'Decrypting...');
  log(`Decrypting...`);
  const decrypted = await crypto.subtle.decrypt(algoParams, key, ciphertext);
  return new Uint8Array(decrypted);
}

// ─── Main Process ─────────────────────────────────────────────────────────────
async function processFile() {
  if (!selectedFile) { alert('Please select a file first.'); return; }
  const password = document.getElementById('passwordInput').value;
  if (!password) { alert('Please enter a passphrase.'); return; }

  const btn = document.getElementById('actionBtn');
  btn.disabled = true;
  resetResult();

  const startTime = Date.now();

  try {
    log(`VAULT v1.0 — ${currentMode.toUpperCase()} mode`, 'info');
    log(`File: ${selectedFile.name} (${formatSize(selectedFile.size)})`, 'info');
    log(`Algorithm: ${selectedAlgo}-256`, 'info');
    log(`Reading file data...`, 'info');
    setProgress(5, 'Reading file...');

    const fileBuffer = await selectedFile.arrayBuffer();
    const fileData = new Uint8Array(fileBuffer);

    let outputData, outputFilename;

    if (currentMode === 'encrypt') {
      // Optionally embed metadata header
      let payload = fileData;
      if (options.embedMeta) {
        const metaStr = JSON.stringify({ name: selectedFile.name, type: selectedFile.type, size: selectedFile.size });
        const metaBytes = new TextEncoder().encode(metaStr);
        const metaLen = new Uint8Array(4);
        new DataView(metaLen.buffer).setUint32(0, metaBytes.length, false);
        const combined = new Uint8Array(metaLen.length + metaBytes.length + payload.length);
        combined.set(metaLen, 0);
        combined.set(metaBytes, 4);
        combined.set(payload, 4 + metaBytes.length);
        payload = combined;
        log(`Metadata embedded (${formatSize(metaBytes.length)})`, 'info');
      }

      setProgress(10, 'Preparing...');
      log(`Generating random salt & IV...`, 'info');
      outputData = await encryptData(payload, password, selectedAlgo);
      outputFilename = selectedFile.name + '.vault';
      log(`Encryption complete! Output: ${formatSize(outputData.length)}`, 'success');

    } else {
      // Decrypt
      let decrypted = await decryptData(fileData, password);

      let originalName = selectedFile.name.replace(/\.vault$/, '') || 'decrypted_file';

      // Try to extract metadata
      if (decrypted.length > 4) {
        try {
          const metaLen = new DataView(decrypted.buffer, decrypted.byteOffset, 4).getUint32(0, false);
          if (metaLen < 1000 && metaLen > 0 && decrypted.length > 4 + metaLen) {
            const metaStr = new TextDecoder().decode(decrypted.slice(4, 4 + metaLen));
            const meta = JSON.parse(metaStr);
            originalName = meta.name || originalName;
            decrypted = decrypted.slice(4 + metaLen);
            log(`Metadata recovered: ${meta.name}`, 'success');
          }
        } catch(e) { /* no metadata */ }
      }

      outputData = decrypted;
      outputFilename = originalName;
      log(`Decryption complete! Output: ${formatSize(outputData.length)}`, 'success');
    }

    setProgress(90, 'Finalizing...');
    const elapsed = ((Date.now() - startTime) / 1000).toFixed(2);
    const speed = (selectedFile.size / 1024 / 1024 / parseFloat(elapsed)).toFixed(1);

    resultBlob = new Blob([outputData]);
    resultFilename = outputFilename;

    setProgress(100, 'Complete!');
    log(`Done in ${elapsed}s at ${speed} MB/s`, 'success');

    // Update stats
    statsFiles++;
    statsBytes += selectedFile.size;
    document.getElementById('statFiles').textContent = statsFiles;
    document.getElementById('statSize').textContent = formatSize(statsBytes);

    // Show result
    const rb = document.getElementById('resultBox');
    rb.className = 'result-box show success-box';
    document.getElementById('resultTitle').textContent = currentMode === 'encrypt'
      ? '✅ FILE ENCRYPTED SUCCESSFULLY' : '✅ FILE DECRYPTED SUCCESSFULLY';

    document.getElementById('resultDetails').innerHTML = `
      <div class="detail-item">
        <span class="detail-val">${formatSize(selectedFile.size)}</span>
        <span class="detail-key">Input Size</span>
      </div>
      <div class="detail-item">
        <span class="detail-val">${formatSize(outputData.length)}</span>
        <span class="detail-key">Output Size</span>
      </div>
      <div class="detail-item">
        <span class="detail-val">${elapsed}s</span>
        <span class="detail-key">Time Elapsed</span>
      </div>`;

  } catch (err) {
    log(`ERROR: ${err.message}`, 'error');
    setProgress(0, 'Failed');
    const rb = document.getElementById('resultBox');
    rb.className = 'result-box show error-box';
    document.getElementById('resultTitle').textContent = '❌ OPERATION FAILED';
    document.getElementById('resultDetails').innerHTML = `<div class="detail-item" style="grid-column:1/-1"><span class="detail-val" style="color:var(--red);font-size:.8rem">${err.message}</span></div>`;
    document.getElementById('downloadBtn').style.display = 'none';
  } finally {
    btn.disabled = false;
  }
}

function downloadResult() {
  if (!resultBlob) return;
  const a = document.createElement('a');
  a.href = URL.createObjectURL(resultBlob);
  a.download = resultFilename;
  a.click();
  setTimeout(() => URL.revokeObjectURL(a.href), 10000);
  log(`File saved: ${resultFilename}`, 'success');
}
</script>
</body>
</html>
